# ── AI Provider ────────────────────────────────────────────────────────────
# Which AI provider to use for test synthesis and code fixes.
# Supported values: "github" | "copilot" | "openai" | "anthropic"
#
# RECOMMENDED: Use your GitHub Copilot subscription (free with Copilot plan)
# 1. Go to: https://github.com/settings/tokens?type=beta
# 2. Click "Generate new token" → name it "EZTest"
# 3. Under Account permissions → Models → set to "Read-only"
# 4. Copy the token (starts with "github_pat_" or "ghp_")
#
EZTEST_GITHUB_TOKEN=github_pat_...

# ── Copilot Chat API (higher token limits, 0x premium models) ───────────────
# Set EZTEST_AI_PROVIDER=copilot to use api.githubcopilot.com instead of
# the GitHub Models API. This gives 16 384 output tokens (vs 4 096) and no
# per-model daily quotas for the 0x-premium models (gpt-4.1, gpt-5-mini).
#
# Requirements:
#   - gh CLI installed:  https://cli.github.com
#   - Authenticated:     gh auth login  (run once)
#   - Active Copilot Pro or Pro+ subscription on your GitHub account
#
# EZTEST_AI_PROVIDER=copilot

# OpenAI API key — use if you prefer OpenAI over GitHub Copilot
# Get one at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Anthropic API key — use if you prefer Claude over GitHub Copilot
# Get one at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=sk-ant-...

# ── AI Model ────────────────────────────────────────────────────────────────
# Override the default model used for AI calls.
# GitHub Copilot default: gpt-4o
# OpenAI default:         gpt-4o
# Anthropic default:      claude-3-5-sonnet-20241022
# EZTEST_AI_MODEL=gpt-4o

# ── Session Recorder ────────────────────────────────────────────────────────
# URL of the application you want to record against.
# Can also be passed as a CLI argument: eztest record --url http://localhost:3000
EZTEST_TARGET_URL=http://localhost:3000

# Port for the annotation overlay server (default: 7432)
# EZTEST_ANNOTATION_SERVER_PORT=7432

# ── Test Synthesizer ────────────────────────────────────────────────────────
# Root directory of the application source code to analyze.
# Can also be passed as a CLI argument: eztest generate --source ./src
# EZTEST_SOURCE_DIR=./src

# Directory where generated Playwright test files are written.
# EZTEST_OUTPUT_DIR=./tests/generated

# ── Forge Terminal Integration ──────────────────────────────────────────────
# MCP server URL — preferred delivery method. Provides task acknowledgement + status.
# Set this to your running Forge Terminal instance.
# EZTEST_FORGE_MCP_URL=http://localhost:3005/api/mcp

# MCP bearer token — read from ~/.forge/mcp-token after starting Forge Terminal.
# EZTEST_FORGE_MCP_TOKEN=<paste token from ~/.forge/mcp-token>

# Webhook URL fallback — used when MCP is not configured.
# EZTEST_FORGE_WEBHOOK_URL=https://forge.example.com/webhook/your-agent-id
